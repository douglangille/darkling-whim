---
layout: null
permalink: /substack.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
<channel>
<title>{{ site.title | xml_escape }}</title>
<description>{{ site.description | xml_escape }}</description>
<link>{{ "/" | absolute_url }}</link>
<atom:link href="{{ "/fullfeed.xml" | absolute_url }}" rel="self" type="application/rss+xml"/>
<language>{{ site.lang | default: "en-US" }}</language>
<lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {% for post in site.posts limit:2 %}
    {% assign post_url = post.url | absolute_url %}
    {% assign canonical_html = '<blockquote><em>Originally published at <a href="' | append: post_url | append: '">Darkling Whim</a>.</em></blockquote>' %}
    {% assign body_html = post.content | replace: post.title, '' %}
    {% assign body_html = body_html | replace: '<h1>', '' | replace: '</h1>', '' %}
    {% assign parts = body_html | split: '</p>' %}
    {% assign feature_img = post.header.teaser | default: post.header.overlay_image | default: post.feature %}
    {% if feature_img %}
      {% assign feature_url = feature_img | absolute_url %}
    {% endif %}
<item>
<title>{{ post.title | xml_escape }}</title>
<link>{{ post_url }}</link>
<guid isPermaLink="true">{{ post_url }}</guid>
<pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
<description><![CDATA[
  {% if feature_url %}<img src="{{ feature_url }}" alt="{{ post.title }}" style="max-width:100%; margin-bottom:1em;">{% endif %}
  {{ parts[0] }}</p>
  {{ parts[1] }}</p>
  {{ canonical_html }}
  {% for part in parts %}
    {% if forloop.index0 >= 2 %}
      {{ part }}{% unless forloop.last %}</p>{% endunless %}
    {% endif %}
  {% endfor %}
]]></description>
      {% for tag in post.tags %}
<category>{{ tag | xml_escape }}</category>
      {% endfor %}
      {% if feature_url %}
<media:content url="{{ feature_url }}" medium="image"/>
<enclosure url="{{ feature_url }}" type="image/jpeg" length="0"/>
      {% endif %}
</item>
    {% endfor %}
</channel>
</rss>